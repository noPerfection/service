{
  "services": [
    {
      "handlers": [
        {
          "category": "main",
          "endpoint": {
            "id": "default-name-proxy",
            "port": 0
          },
          "forward": {
            "hello": "pkg:json/.#noPerfection.json?var=services[name:hello-world]\u0026category=main"
          },
          "outbounds": [
            "pkg:json/.#noPerfection.json?var=services[name:hello-world]\u0026category=main"
          ],
          "routes": [
            "hello"
          ],
          "type": "SyncReplier"
        }
      ],
      "module-url": "pkg:golang/github.com/noPerfection/service/examples/009-inproc-services#services/proxy?root=/home/medet/noPerfection/service/examples/009-inproc-services",
      "name": "default-name-proxy",
      "start-command": "./bin/proxy",
      "type": "Proxy"
    },
    {
      "handlers": [
        {
          "category": "main",
          "endpoint": {
            "id": "tmp/entrypoint",
            "port": 0
          },
          "forward": {
            "hello": "pkg:json/.#noPerfection.json?var=services[name:default-name-proxy]\u0026category=main"
          },
          "outbounds": [
            "pkg:json/.#noPerfection.json?var=services[name:hello-world]\u0026category=main",
            "pkg:json/.#noPerfection.json?var=services[name:default-name-proxy]\u0026category=main"
          ],
          "routes": [
            "age-verification",
            "hello"
          ],
          "type": "SyncReplier"
        }
      ],
      "module-url": "pkg:golang/github.com/noPerfection/service/examples/009-inproc-services#services/entrypoint?root=/home/medet/noPerfection/service/examples/009-inproc-services",
      "name": "entrypoint",
      "parameters": {
        "inproc-handlers": [
          "main"
        ]
      },
      "start-command": "./bin/entrypoint",
      "type": "Proxy"
    },
    {
      "handler-deps": [
        {
          "name": "main",
          "proxies": [
            "pkg:$?var=services[name:entrypoint]"
          ]
        },
        {
          "extensions": [
            "ai",
            "pkg:$?var=services[name:inproc-topology]"
          ],
          "name": "manager"
        }
      ],
      "handlers": [
        {
          "category": "main",
          "command-deps": [
            {
              "name": "hello",
              "proxies": [
                "pkg:$?var=services[name:default-name-proxy]"
              ]
            }
          ],
          "endpoint": {
            "id": "hello-world",
            "port": 0
          },
          "type": "SyncReplier"
        }
      ],
      "module-url": "pkg:golang/github.com/noPerfection/service/examples/009-inproc-services#/cmd/service?main=true\u0026root=/home/medet/noPerfection/service/examples/009-inproc-services",
      "name": "hello-world",
      "type": "Independent"
    },
    {
      "handlers": [
        {
          "category": "manager",
          "endpoint": {
            "id": "ai_manager",
            "port": 0
          },
          "type": "SyncReplier"
        },
        {
          "category": "main",
          "endpoint": {
            "id": "ai",
            "port": 0
          },
          "inbounds": null,
          "type": "Replier"
        }
      ],
      "module-url": "pkg:golang/github.com/noPerfection/service",
      "name": "ai",
      "parameters": {
        "api-key": "*pkg:os/env?var=ANTHROPIC_API_KEY\u0026LoadAnyEnv=true",
        "model": "claude-haiku-4-5-20251001"
      },
      "type": "Extension"
    },
    {
      "handlers": [
        {
          "category": "manager",
          "endpoint": {
            "id": "inproc-topology_manager",
            "port": 0
          },
          "type": "SyncReplier"
        },
        {
          "category": "main",
          "endpoint": {
            "id": "inproc-topology",
            "port": 0
          },
          "inbounds": null,
          "type": "Replier"
        }
      ],
      "module-url": "pkg:golang/github.com/noPerfection/service",
      "name": "inproc-topology",
      "type": "Extension"
    }
  ]
}
