{
  "services": [
    {
      "type": "Proxy",
      "name": "default-name-proxy",
      "module-url": "github.com/noPerfection/service/examples/007-handler-deps/cmd/proxy",
      "handlers": [
        {
          "type": "SyncReplier",
          "category": "main",
          "endpoint": {
            "id": "localhost",
            "port": 8001
          },
          "routes": ["hello"],
          "outbounds": []
        }
      ]
    },
    {
      "type": "Proxy",
      "name": "entrypoint",
      "module-url": "github.com/noPerfection/service/examples/007-handler-deps/cmd/entrypoint",
      "handlers": [
        {
          "type": "SyncReplier",
          "category": "main",
          "endpoint": {
            "id": "localhost",
            "port": 8003
          },
          "routes": ["hello", "age-verification"],
          "outbounds": []
        }
      ]
    },
    {
      "type": "Independent",
      "name": "hello-world",
      "module-url": "github.com/noPerfection/service",
      "handler-deps": [
        {
          "name": "main",
          "proxies": ["pkg:$?var=services[name:entrypoint]"]
        }
      ],
      "handlers": [
        {
          "type": "Replier",
          "category": "main",
          "endpoint": {
            "id": "localhost",
            "port": 8000
          },
          "command-deps": [
            {
              "name": "hello",
              "proxies": ["pkg:$?var=services[name:default-name-proxy]"]
            }
          ]
        }
      ]
    }
  ]
}
