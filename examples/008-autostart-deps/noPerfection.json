{
  "services": [
    {
      "type": "Proxy",
      "name": "default-name-proxy",
      "module-url": "github.com/noPerfection/service/examples/008-autostart-deps/cmd/proxy",
      "start-command": "./bin/proxy",
      "handlers": [
        {
          "type": "SyncReplier",
          "category": "main",
          "endpoint": {
            "id": "tmp/default_name_proxy",
            "port": 0
          },
          "routes": [
            "hello"
          ],
          "outbounds": [
            {
              "type": "Independent",
              "name": "hello-world",
              "module-url": "github.com/noPerfection/service",
              "handler-deps": [
                {
                  "name": "main",
                  "proxies": [
                    "entrypoint"
                  ]
                }
              ],
              "handlers": [
                {
                  "type": "Replier",
                  "category": "main",
                  "endpoint": {
                    "id": "localhost",
                    "port": 8000
                  },
                  "command-deps": [
                    {
                      "name": "hello",
                      "proxies": [
                        "default-name-proxy"
                      ]
                    }
                  ]
                }
              ]
            }
          ],
          "forward": {
            "hello": "hello-world/main"
          }
        },
        {
          "type": "SyncReplier",
          "category": "manager",
          "endpoint": {
            "id": "tmp/default_name_proxy_manager",
            "port": 0
          }
        }
      ]
    },
    {
      "type": "Proxy",
      "name": "entrypoint",
      "module-url": "github.com/noPerfection/service/examples/008-autostart-deps/cmd/entrypoint",
      "start-command": "./bin/entrypoint",
      "handlers": [
        {
          "type": "SyncReplier",
          "category": "main",
          "endpoint": {
            "id": "tmp/entrypoint_proxy",
            "port": 0
          },
          "routes": [
            "age-verification",
            "hello"
          ],
          "outbounds": [
            {
              "type": "Independent",
              "name": "hello-world",
              "module-url": "github.com/noPerfection/service",
              "handler-deps": [
                {
                  "name": "main",
                  "proxies": [
                    "entrypoint"
                  ]
                }
              ],
              "handlers": [
                {
                  "type": "Replier",
                  "category": "main",
                  "endpoint": {
                    "id": "localhost",
                    "port": 8000
                  },
                  "command-deps": [
                    {
                      "name": "hello",
                      "proxies": [
                        "default-name-proxy"
                      ]
                    }
                  ]
                }
              ]
            },
            {
              "type": "Proxy",
              "name": "default-name-proxy",
              "module-url": "github.com/noPerfection/service/examples/008-autostart-deps/cmd/proxy",
              "start-command": "./bin/proxy",
              "handlers": [
                {
                  "type": "SyncReplier",
                  "category": "main",
                  "endpoint": {
                    "id": "tmp/default_name_proxy",
                    "port": 0
                  },
                  "outbounds": null
                }
              ]
            }
          ],
          "forward": {
            "hello": "default-name-proxy/main"
          }
        },
        {
          "type": "SyncReplier",
          "category": "manager",
          "endpoint": {
            "id": "tmp/entrypoint_proxy_manager",
            "port": 0
          }
        }
      ]
    },
    {
      "type": "Independent",
      "name": "hello-world",
      "module-url": "github.com/noPerfection/service",
      "handler-deps": [
        {
          "name": "main",
          "proxies": [
            "entrypoint"
          ]
        }
      ],
      "handlers": [
        {
          "type": "Replier",
          "category": "main",
          "endpoint": {
            "id": "localhost",
            "port": 8000
          },
          "command-deps": [
            {
              "name": "hello",
              "proxies": [
                "default-name-proxy"
              ]
            }
          ]
        },
        {
          "type": "SyncReplier",
          "category": "manager",
          "endpoint": {
            "id": "localhost",
            "port": 8001
          }
        }
      ]
    }
  ]
}
