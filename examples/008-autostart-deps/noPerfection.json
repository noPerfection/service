{
  "services": [
    {
      "handlers": [
        {
          "category": "main",
          "endpoint": {
            "id": "tmp/default_name_proxy",
            "port": 0
          },
          "forward": {
            "hello": "pkg:json/.#noPerfection.json?var=services[name:hello-world]\u0026category=main"
          },
          "outbounds": [
            "pkg:json/.#noPerfection.json?var=services[name:hello-world]\u0026category=main"
          ],
          "routes": [
            "hello"
          ],
          "type": "SyncReplier"
        },
        {
          "category": "manager",
          "endpoint": {
            "id": "tmp/default_name_proxy_manager",
            "port": 0
          },
          "type": "SyncReplier"
        }
      ],
      "module-url": "github.com/noPerfection/service/examples/008-autostart-deps/cmd/proxy",
      "name": "default-name-proxy",
      "start-command": "./bin/proxy",
      "type": "Proxy"
    },
    {
      "handlers": [
        {
          "category": "main",
          "endpoint": {
            "id": "tmp/entrypoint_proxy",
            "port": 0
          },
          "forward": {
            "hello": "pkg:json/.#noPerfection.json?var=services[name:default-name-proxy]\u0026category=main"
          },
          "outbounds": [
            "pkg:json/.#noPerfection.json?var=services[name:hello-world]\u0026category=main",
            "pkg:json/.#noPerfection.json?var=services[name:default-name-proxy]\u0026category=main"
          ],
          "routes": [
            "age-verification",
            "hello"
          ],
          "type": "SyncReplier"
        },
        {
          "category": "manager",
          "endpoint": {
            "id": "tmp/entrypoint_proxy_manager",
            "port": 0
          },
          "type": "SyncReplier"
        }
      ],
      "module-url": "github.com/noPerfection/service/examples/008-autostart-deps/cmd/entrypoint",
      "name": "entrypoint",
      "start-command": "./bin/entrypoint",
      "type": "Proxy"
    },
    {
      "handler-deps": [
        {
          "name": "main",
          "proxies": [
            "pkg:$?var=services[name:entrypoint]"
          ]
        }
      ],
      "handlers": [
        {
          "category": "main",
          "command-deps": [
            {
              "name": "hello",
              "proxies": [
                "pkg:$?var=services[name:default-name-proxy]"
              ]
            }
          ],
          "endpoint": {
            "id": "localhost",
            "port": 8000
          },
          "type": "Replier"
        },
        {
          "category": "manager",
          "endpoint": {
            "id": "localhost",
            "port": 8001
          },
          "type": "SyncReplier"
        }
      ],
      "module-url": "github.com/noPerfection/service",
      "name": "hello-world",
      "type": "Independent"
    }
  ]
}
