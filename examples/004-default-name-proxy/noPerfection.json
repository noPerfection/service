{
  "services": [
    {
      "handlers": [
        {
          "category": "main",
          "endpoint": {
            "id": "localhost",
            "port": 8001
          },
          "outbounds": [
            "pkg:$?var=services[name:hello-world]\u0026category=main"
          ],
          "routes": [
            "*"
          ],
          "type": "SyncReplier"
        }
      ],
      "module-url": "github.com/noPerfection/service/examples/004-default-name-proxy/cmd/proxy",
      "name": "default-name-proxy",
      "type": "Proxy"
    },
    {
      "handlers": [
        {
          "category": "main",
          "endpoint": {
            "id": "localhost",
            "port": 8000
          },
          "type": "Replier"
        }
      ],
      "module-url": "github.com/noPerfection/service",
      "name": "hello-world",
      "type": "Independent"
    }
  ]
}
