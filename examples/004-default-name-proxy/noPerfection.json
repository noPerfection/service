{
  "services": [
    {
      "type": "Proxy",
      "name": "default-name-proxy",
      "module-url": "github.com/noPerfection/service/examples/004-default-name-proxy/cmd/proxy",
      "handlers": [
        {
          "type": "SyncReplier",
          "category": "default-name",
          "endpoint": {
            "id": "localhost",
            "port": 8001
          },
          "routes": [
            "*"
          ],
          "outbounds": [
            {
              "type": "Independent",
              "name": "hello-world",
              "module-url": "github.com/noPerfection/service/examples/004-default-name-proxy/cmd/service",
              "handlers": [
                {
                  "type": "Replier",
                  "category": "main",
                  "endpoint": {
                    "id": "localhost",
                    "port": 8000
                  }
                }
              ]
            }
          ]
        },
        {
          "type": "SyncReplier",
          "category": "manager",
          "endpoint": {
            "id": "default-name-proxy_proxy_manager",
            "port": 0
          }
        }
      ]
    },
    {
      "type": "Independent",
      "name": "hello-world",
      "module-url": "github.com/noPerfection/service",
      "handlers": [
        {
          "type": "Replier",
          "category": "main",
          "endpoint": {
            "id": "localhost",
            "port": 8000
          }
        }
      ]
    }
  ]
}
